# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/motorcycle_rides?schema=public"

# ============================================
# REDIS
# ============================================
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# ============================================
# CLERK AUTHENTICATION
# ============================================
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxx"
CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxx"
CLERK_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxx"

# Mock mode for development (set to "false" for production)
CLERK_MOCK_MODE="true"

# ============================================
# GOOGLE MAPS
# ============================================
GOOGLE_MAPS_API_KEY="your_google_maps_api_key_here"

# Maps provider: "google" | "mapbox" | "ola"
MAPS_PROVIDER="google"

# ============================================
# APPLICATION
# ============================================
PORT=3000
NODE_ENV="development"

# CORS origins (comma-separated)
CORS_ORIGINS="http://localhost:8081,exp://192.168.1.100:8081"

# ============================================
# JWT (for WebSocket auth - optional)
# ============================================
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
```

